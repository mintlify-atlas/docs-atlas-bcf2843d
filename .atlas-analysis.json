  "publicApiSurface": [
    "POST /login - User authentication",
    "GET /dashboard - Main dashboard",
    "GET /reports - List all reports",
    "GET /reports/{groupId}/{reportId}/view - View Power BI report",
    "POST /reports - Create new report",
    "GET /users - User management",
    "POST /users/update-reports - Assign reports to users",
    "GET /roles - Role management",
    "POST /roles - Create new role",
    "GET /design/request - Design requests",
    "GET /lista-precios - Price list module",
    "GET /rutas-tecnicas - Technical routes module",
    "POST /reports/import - Import Power BI reports",
